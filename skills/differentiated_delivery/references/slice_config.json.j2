{
  "differentiated_delivery": {
    "slice": {
      "type": "{{ slice_type }}",
      "target_app": "{{ target_app }}",
      "bandwidth_guarantee_mbps": {{ bandwidth_guarantee_mbps }}
    },
    "whitelist": [{% for item in whitelist %}"{{ item }}"{{ ", " if not loop.last else "" }}{% endfor %}],
    "forwarding_policy": {
      "priority": "high",
      "scheduler": "wfq"
    }
  }
}
