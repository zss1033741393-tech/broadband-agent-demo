{
  "description": "模拟一次「WiFi 补点仿真」场景的 SSE 流式响应，使用 wifi_result 事件推送图片。",
  "request": {
    "method": "POST",
    "path": "/conversations/conv_001/messages",
    "body": {
      "content": "帮我对大平层做一次 WiFi 补点仿真分析，当前只有 1 个 AP，目标 3 个 AP。",
      "deepThinking": false
    }
  },
  "events": [
    { "delayMs": 0,    "event": "thinking", "data": { "delta": "用户需要对大平层做 WiFi 补点仿真。" } },
    { "delayMs": 200,  "event": "thinking", "data": { "delta": "当前 1 AP → 目标 3 AP，需计算 RSSI 和卡顿率变化。" } },

    { "delayMs": 400,  "event": "step_start", "data": { "stepId": "step_001", "title": "扫描当前 AP 分布" } },
    { "delayMs": 600,  "event": "sub_step",   "data": { "stepId": "step_001", "subStepId": "sub_001", "name": "读取 AP 位置数据", "completedAt": "2026-04-08T09:12:18Z", "durationMs": 312 } },
    { "delayMs": 900,  "event": "sub_step",   "data": { "stepId": "step_001", "subStepId": "sub_002", "name": "生成热力图底图", "completedAt": "2026-04-08T09:12:21Z", "durationMs": 480 } },
    { "delayMs": 1100, "event": "step_end",   "data": { "stepId": "step_001" } },

    { "delayMs": 1300, "event": "step_start", "data": { "stepId": "step_002", "title": "运行补点仿真算法" } },
    { "delayMs": 1500, "event": "sub_step",   "data": { "stepId": "step_002", "subStepId": "sub_003", "name": "计算最优 AP 位置", "completedAt": "2026-04-08T09:12:28Z", "durationMs": 1450 } },
    { "delayMs": 1800, "event": "sub_step",   "data": { "stepId": "step_002", "subStepId": "sub_004", "name": "渲染 RSSI / 卡顿率对比图", "completedAt": "2026-04-08T09:12:30Z", "durationMs": 820 } },
    { "delayMs": 2000, "event": "step_end",   "data": { "stepId": "step_002" } },

    { "delayMs": 2200, "event": "wifi_result", "data": {
        "renderType": "wifi_simulation",
        "renderData": {
          "preset": "大平层",
          "gridSize": 40,
          "apCount": 1,
          "targetApCount": 3,
          "summary": "大平层 1AP→3AP 补点优化完成；平均 RSSI 由 -72.1dBm 提升至 -55.3dBm，平均卡顿率由 18.2% 降至 2.1%。",
          "stats": {
            "rssi_before":  { "mean_rssi": -72.1, "worst_rssi": -90.0, "shape": [42, 42] },
            "rssi_after":   { "mean_rssi": -55.3, "worst_rssi": -78.5, "shape": [42, 42] },
            "stall_before": { "mean_stall_rate": 0.182, "max_stall_rate": 0.564, "shape": [42, 42] },
            "stall_after":  { "mean_stall_rate": 0.021, "max_stall_rate": 0.097, "shape": [42, 42] }
          },
          "images": [
            { "imageId": "sim001_img_0", "imageUrl": "/api/images/sim001_img_0", "title": "RSSI 对比图（补点前/后）", "kind": "rssi" },
            { "imageId": "sim001_img_1", "imageUrl": "/api/images/sim001_img_1", "title": "卡顿率对比图（补点前/后）", "kind": "stall" }
          ],
          "dataFiles": []
        }
      }
    },

    { "delayMs": 2400, "event": "text", "data": { "delta": "## 仿真结论\n\n大平层补点优化（1AP → 3AP）完成：\n\n" } },
    { "delayMs": 2600, "event": "text", "data": { "delta": "- **平均 RSSI**：-72.1 dBm → **-55.3 dBm**（提升 16.8 dB）\n" } },
    { "delayMs": 2800, "event": "text", "data": { "delta": "- **平均卡顿率**：18.2% → **2.1%**（降低 88%）\n" } },

    { "delayMs": 3000, "event": "done", "data": { "messageId": "msg_wifi_001", "thinkingDurationSec": 8 } }
  ]
}
