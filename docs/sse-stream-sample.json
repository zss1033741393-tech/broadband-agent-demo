  "event_type_reference": {
    "thinking": {
      "payload": {
        "delta": "string（推理内容增量，非空）",
        "stepId": "string?（存在时表示属于某 SubAgent，值为 member_id；不存在时属于 Orchestrator）"
      },
      "frontend_action": "有 stepId → 追加到对应 StepCard 的 thinking 块；无 stepId → 追加到顶层 ThinkingBlock"
    },
    "text": {
      "payload": { "delta": "string（文本增量，非空）" },
      "frontend_action": "追加到最后一个 text block，若无则新建；仅 Orchestrator（Team leader）产生"
    },
    "step_start": {
      "payload": { "stepId": "string", "title": "string" },
      "frontend_action": "关闭前一个 thinking block，push { type:'step', stepId } 到 blocks[]，新建 StepCard（默认展开）"
    },
    "sub_step": {
      "payload": {
        "stepId": "string（所属 SubAgent）",
        "subStepId": "string（唯一 ID，格式 {stepId}_{skillName}）",
        "name": "string（Skill 名称）",
        "scriptPath": "string?（被调用脚本路径，Instructional Skill 为空）",
        "callArgs": "string[]?（CLI 参数列表）",
        "stdout": "string?（脚本 stdout，截断至 500 字符）",
        "stderr": "string?（脚本 stderr，截断至 500 字符）",
        "completedAt": "string（ISO 8601 UTC）",
        "durationMs": "number（执行耗时毫秒）"
      },
      "frontend_action": "关闭当前 thinking block（打 endedAt），追加 { type:'sub_step', data } 到 StepCard.items[]"
    },
    "step_end": {
      "payload": { "stepId": "string" },
      "frontend_action": "关闭末尾 thinking block，标记 StepCard completed（loading → 绿色对勾）"
    },
    "render": {
      "payload": {
        "renderType": "'insight' | 'image'",
        "renderData": "InsightRenderData | ImageRenderData（见 sse-interface-spec.md）"
      },
      "frontend_action": "追加到 message.renderBlocks[]，同步更新右侧 RightPanel；在 insight step_end 之前触发"
    },
    "done": {
      "payload": { "messageId": "string（UUID）", "thinkingDurationSec": "number" },
      "frontend_action": "streaming=false，关闭末尾 thinking block，更新 thinkingDurationSec"
    },
    "error": {
      "payload": { "message": "string" },
      "frontend_action": "显示错误提示，streaming=false；消息不持久化到数据库"
    }
  }
}
